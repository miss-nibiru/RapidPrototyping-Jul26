  m_Script: {fileID: 11500000, guid: 22bdf6e67d8d64da2ad4f22623d22371, type: 3}
  m_Name: SO_ResignationLetter
  m_EditorClassIdentifier: Assembly-CSharp::DocumentData
  fileName: ResignationLetter.docx
  fileIcon: {fileID: 21300000, guid: 4a238560b30ca435bac666a7bcb37f5e, type: 3}
  fileType: 0
  windowTitle: ResignationLetter.docx
  windowIcon: {fileID: 21300000, guid: df977d5ffabd540c1be916c070ef4903, type: 3}
  windowSize: {x: 800, y: 800}
  documentBody: 'Kamila,


    Please accept this letter as my official resignation,
    effective immediately. I CAN''T TAKE THIS ANYMORE!!! WHO SENDS EMAILS AT 3:17
    A.M. KAMILA!?!?


    I would like to thank you for your leadership and guidance.
    I will ensure a smooth transition by documenting my work to the best of my ability


    Thank
    you for everything... Respectfully, I think


    Please don''t call me. Actually
    delete my number. Actually I changed my name


    P.S. I have left detailed
    notes on my computer

    P.S. A printer has become sentient'
